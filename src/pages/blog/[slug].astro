---
// layout + content loading
import Layout from '../../layouts/Layout.astro';
import Comments from '../../components/Comments.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import { getCollection, render } from 'astro:content';
import galleryScriptUrl from '../../scripts/gallery.ts?url';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => data.published);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const tocHeadings = headings.filter(heading => heading.depth >= 1 && heading.depth <= 6);
const showTocRail = tocHeadings.length >= 3;

const parseLocalDate = (dateString: string) => {
  const match = /^(\d{4})-(\d{2})-(\d{2})$/.exec(dateString);
  if (!match) return null;
  const [, year, month, day] = match;
  return new Date(Number(year), Number(month) - 1, Number(day));
};
const parseIsoDate = (dateString?: string) => {
  if (!dateString) return undefined;
  const date = new Date(`${dateString}T00:00:00.000Z`);
  return Number.isNaN(date.getTime()) ? undefined : date.toISOString();
};
const publishedTime = parseIsoDate(post.data.pubDate);
const updatedTime = parseIsoDate(post.data.updatedDate);
const pubDate = parseLocalDate(post.data.pubDate);
const displayDate = pubDate
  ? pubDate.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' }).toLowerCase()
  : post.data.pubDate;
const description = post.data.description ?? 'a short post on something';
const body = typeof post.body === 'string' ? post.body.trim() : '';
const wordCount = body ? body.split(/\s+/).length : 0;
const multiplier = post.data.cat === 'code' ? 1.3 : 1;
const readingTimeMinutes = Math.max(1, Math.round((wordCount / 200) * multiplier));
const readingTimeLabel = readingTimeMinutes < 60
  ? `approx ${readingTimeMinutes}m read`
  : `approx ${Math.floor(readingTimeMinutes / 60)}h${readingTimeMinutes % 60 ? ` ${readingTimeMinutes % 60}m` : ''} read`;
const siteUrl = new URL(import.meta.env.BASE_URL, Astro.site).toString().replace(/\/$/, '');
---
<style>
:root {
  /* adjust these to taste */
  --content-max-width: 800px;
  --side-gutter: 1rem;
}

/* prevent any accidental overflow */
html, body {
  margin: 0;
  padding: 0;
  overflow-x: hidden;
}

/* make all code blocks wrap */
code,
pre {
  white-space: pre-wrap;
  word-break: break-word;
  overflow-wrap: break-word;
}

/* body text line height */
.markdown-body {
  line-height: 1.8;
}

/* Post title styling */
.post-title-main {
  font-size: 2.1rem;
  line-height: 1.2;
  margin: 0 0 0.5rem;
  font-weight: 700;
  letter-spacing: -0.03em;
  font-family: var(--font-mono);
  color: var(--fg-strong);
}

.post-description {
  color: var(--fg-muted);
  margin: 0;
  font-size: 0.98rem;
  line-height: 1.7;
  font-family: var(--font-mono);
}

.post-subline {
  margin-bottom: 2rem;
}

.post-meta {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  color: var(--fg-subtle);
  font-size: 0.85rem;
  letter-spacing: 0.04em;
  font-family: var(--font-mono);
  margin: 0 0 0.6rem;
}

.post-meta-sep {
  color: var(--border-strong);
}

.post-readtime {
  letter-spacing: 0.04em;
}

@media (max-width: 600px) {
  .post-subline {
    flex-direction: column;
    align-items: flex-start;
    gap: 0.4rem;
  }

  .post-meta {
    flex-wrap: wrap;
  }
}

/* --- Sidebar table of contents --- */
.toc-rail {
  position: fixed;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  z-index: 100;
  width: 24px;
  padding: 1.2rem 0 1.2rem 0.4rem;
  transition: width 0.3s ease, background 0.3s ease, box-shadow 0.3s ease;
  overflow-x: hidden;
  overflow-y: auto;
  max-height: calc(100vh - 2rem);
  border-radius: 0 8px 8px 0;
  scrollbar-width: thin;
  scrollbar-color: var(--border-strong) transparent;
  overscroll-behavior: contain;
}

.toc-rail::-webkit-scrollbar {
  width: 6px;
}
.toc-rail::-webkit-scrollbar-thumb {
  background: var(--border-strong);
  border-radius: 3px;
}
.toc-rail::-webkit-scrollbar-track {
  background: transparent;
}

/* Hide scrollbar when collapsed (24px wide) — only show on hover / when expanded / pinned */
.toc-rail:not(:hover):not(.is-open):not(.toc-pinned) {
  scrollbar-width: none;
}
.toc-rail:not(:hover):not(.is-open):not(.toc-pinned)::-webkit-scrollbar {
  display: none;
}

/* Pin + hide controls */
.toc-controls {
  display: none;
  justify-content: flex-end;
  gap: 0.3rem;
  margin-bottom: 0.6rem;
  padding-bottom: 0.5rem;
  border-bottom: 1px solid var(--border-soft);
}
.toc-rail:hover .toc-controls,
.toc-rail.is-open .toc-controls,
.toc-rail.toc-pinned .toc-controls {
  display: flex;
}
.toc-ctrl-btn {
  width: 26px;
  height: 26px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: transparent;
  border: 1px solid var(--border-soft);
  color: var(--fg-muted);
  border-radius: 5px;
  cursor: pointer;
  padding: 0;
}
.toc-ctrl-btn svg {
  width: 14px;
  height: 14px;
}
.toc-ctrl-btn:hover {
  color: var(--accent);
  border-color: var(--accent);
}
.toc-ctrl-btn[aria-pressed="true"] {
  color: var(--accent);
  border-color: var(--accent);
  background: rgba(var(--accent-rgb), 0.1);
}
.toc-ctrl-btn:focus-visible {
  outline: 2px solid rgba(var(--accent-rgb), 0.5);
  outline-offset: 2px;
}

/* Pinned: stay expanded permanently (desktop) */
.toc-rail.toc-pinned {
  width: 280px;
  background: var(--bg);
  box-shadow: 2px 0 16px rgba(var(--shadow-rgb), 0.24);
  padding: 1.2rem 0.8rem 1.2rem 0.8rem;
}
.toc-rail.toc-pinned .toc-label {
  opacity: 1;
}

/* Hidden / dismissed state */
.toc-rail.toc-dismissed {
  display: none;
}
/* When dismissed, also hide the mobile floating toggle button to avoid confusion */
.toc-rail.toc-dismissed ~ .toc-mobile-toggle {
  display: none;
}

/* Custom tooltip for truncated TOC labels — shows full text on hover.
   Only applied to entries marked with [data-truncated="true"] by JS. */
.toc-entry[data-truncated="true"] {
  position: relative;
}
.toc-entry[data-truncated="true"] a:hover .toc-label::after,
.toc-entry[data-truncated="true"] a:focus-visible .toc-label::after {
  content: attr(data-full-text);
  position: absolute;
  left: calc(100% + 8px);
  top: 50%;
  transform: translateY(-50%);
  background: var(--bg);
  color: var(--fg);
  border: 1px solid var(--border-strong);
  border-radius: 6px;
  padding: 0.4rem 0.65rem;
  font-size: 0.78rem;
  font-family: var(--font-mono);
  line-height: 1.4;
  white-space: normal;
  max-width: 320px;
  width: max-content;
  box-shadow: 0 4px 14px rgba(var(--shadow-rgb), 0.22);
  z-index: 250;
  pointer-events: none;
  opacity: 0;
  animation: toc-tooltip-fade 0.12s ease-out 0.25s forwards;
}
@keyframes toc-tooltip-fade {
  to { opacity: 1; }
}

/* On mobile drawer, tooltip can collide with edge — anchor inside drawer */
@media (max-width: 1024px) {
  .toc-entry[data-truncated="true"] a:hover .toc-label::after,
  .toc-entry[data-truncated="true"] a:focus-visible .toc-label::after {
    left: 1rem;
    right: 1rem;
    top: 100%;
    transform: none;
    margin-top: 4px;
    max-width: none;
    width: auto;
  }
}

/* Restore tab — small handle on left edge to bring TOC back */
.toc-restore {
  display: none;
  position: fixed;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 28px;
  height: 56px;
  align-items: center;
  justify-content: center;
  background: var(--surface-soft);
  border: 1px solid var(--border-soft);
  border-left: none;
  border-radius: 0 8px 8px 0;
  color: var(--fg-muted);
  cursor: pointer;
  z-index: 99;
  padding: 0;
  box-shadow: 2px 0 8px rgba(var(--shadow-rgb), 0.18);
}
.toc-restore.is-visible {
  display: inline-flex;
}
.toc-restore:hover {
  color: var(--accent);
  border-color: var(--accent);
}
.toc-restore svg {
  width: 16px;
  height: 16px;
}
.toc-restore:focus-visible {
  outline: 2px solid rgba(var(--accent-rgb), 0.5);
  outline-offset: 2px;
}

.toc-rail:hover {
  width: 280px;
  background: var(--bg);
  box-shadow: 2px 0 16px rgba(var(--shadow-rgb), 0.24);
  padding: 1.2rem 0.8rem 1.2rem 0.8rem;
}

.toc-entries {
  list-style: none;
  padding: 0;
  margin: 0;
}

.toc-entry {
  margin: 0;
}

.toc-entry a {
  display: flex;
  align-items: center;
  gap: 0.6rem;
  text-decoration: none;
  padding: 0.25rem 0;
  transition: color 0.15s;
}

.toc-tick {
  flex-shrink: 0;
  height: 2px;
  background: var(--border-strong);
  border-radius: 1px;
  transition: background 0.2s, width 0.2s;
}

.toc-entry-title .toc-tick { width: 24px; height: 3px; }
.toc-entry-title .toc-label { font-weight: 700; color: var(--fg); }
.toc-entry-title { margin-bottom: 0.3rem; }

.toc-d1 .toc-tick { width: 20px; height: 2.5px; }
.toc-d2 .toc-tick { width: 16px; }
.toc-d3 .toc-tick { width: 12px; }
.toc-d4 .toc-tick { width: 8px; }
.toc-d5 .toc-tick { width: 5px; }
.toc-d6 .toc-tick { width: 3px; }

.toc-d1 .toc-label { font-weight: 600; color: var(--fg); }
.toc-d2 .toc-label { font-weight: 500; }
.toc-d4 .toc-label,
.toc-d5 .toc-label,
.toc-d6 .toc-label { font-size: 0.74rem; color: var(--fg-muted); }

.toc-label {
  opacity: 0;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
  font-size: 0.78rem;
  font-family: var(--font-mono);
  color: var(--fg-faint);
  transition: opacity 0.2s ease 0.1s;
}

.toc-rail:hover .toc-label {
  opacity: 1;
}

/* Active heading */
.toc-entry.toc-active .toc-tick {
  background: var(--accent);
}

.toc-entry.toc-active .toc-label {
  color: var(--fg);
  font-weight: 600;
}

/* Hover on individual items */
.toc-entry a:hover .toc-label {
  color: var(--accent);
}

.toc-entry a:hover .toc-tick {
  background: var(--accent);
}

/* Depth indentation (only visible when expanded) */
.toc-d2 a { padding-left: 0.6rem; }
.toc-d3 a { padding-left: 1.2rem; }
.toc-d4 a { padding-left: 1.8rem; }
.toc-d5 a { padding-left: 2.4rem; }
.toc-d6 a { padding-left: 3rem; }

.toc-mobile-toggle {
  display: none;
  position: fixed;
  left: clamp(1rem, 3vw, 1.75rem);
  bottom: clamp(1rem, 3vw, 1.75rem);
  width: 44px;
  height: 44px;
  border-radius: 999px;
  border: 1px solid var(--border-strong);
  background: var(--surface-soft);
  color: var(--fg);
  cursor: pointer;
  z-index: 150;
  place-items: center;
  box-shadow: 0 6px 18px rgba(var(--shadow-rgb), 0.22);
}

.toc-mobile-toggle svg {
  width: 18px;
  height: 18px;
}

.toc-mobile-toggle:focus-visible {
  outline: 2px solid rgba(var(--accent-rgb), 0.5);
  outline-offset: 2px;
}

.toc-mobile-backdrop {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0, 0, 0, 0.4);
  z-index: 199;
  opacity: 0;
  transition: opacity 0.2s ease;
}

.toc-mobile-backdrop.is-open {
  display: block;
  opacity: 1;
}

/* Mobile/narrow screens: convert rail to slide-in drawer */
@media (max-width: 1024px) {
  .toc-rail {
    top: 0;
    bottom: 0;
    transform: translateX(-100%);
    height: 100vh;
    width: min(320px, 86vw);
    max-width: none;
    padding: 1.2rem;
    background: var(--bg);
    border-right: 1px solid var(--border-soft);
    border-radius: 0;
    box-shadow: 4px 0 24px rgba(var(--shadow-rgb), 0.28);
    overflow-y: auto;
    transition: transform 0.25s ease;
    z-index: 200;
  }

  .toc-rail.is-open {
    transform: translateX(0);
  }

  .toc-rail:hover {
    width: min(320px, 86vw);
    background: var(--bg);
    box-shadow: 4px 0 24px rgba(var(--shadow-rgb), 0.28);
    padding: 1.2rem;
  }

  .toc-rail .toc-label {
    opacity: 1;
  }

  .toc-mobile-toggle {
    display: grid;
  }
}

/* Perfect centering wrapper */
.centered-wrapper {
  display: grid;
  grid-template-columns: minmax(var(--side-gutter), 1fr) min(var(--content-max-width), calc(100% - (var(--side-gutter) * 2))) minmax(var(--side-gutter), 1fr);
  width: 100%;
}

.centered-wrapper > * {
  grid-column: 2;
}

/* main article container */
article.post-plain {
  box-shadow: none;
  background: none;
  border: none;

  /* fluid width up to a max, centered */
  width: 100%;
  max-width: var(--content-max-width);
  margin: 3rem auto;         /* top/bottom breathing room, centered */
  padding: 0;                /* remove side padding */
  box-sizing: border-box;
  
  /* Apply equal padding left and right for better centering */
  padding-left: var(--side-gutter);
  padding-right: var(--side-gutter);
}

article.post-plain :global(img) {
  max-width: 600px;
  width: 100%;
  height: auto;
  display: block;
  margin: 1.5rem auto;
}
article.post-plain :global(img[width]) {
  width: auto;
  max-width: 100%;
}

/* tweak typography on small screens if you like */
@media (max-width: 600px) {
  :root {
    --side-gutter: 0.6rem;
  }

  .markdown-body {
    line-height: 1.6;
  }

  .post-title-main {
    font-size: 1.5rem;
    margin-top: 0.5rem;
    letter-spacing: -0.02em;
  }
  .post-description {
    font-size: 0.9rem;
    line-height: 1.55;
  }
  .post-meta {
    font-size: 0.78rem;
  }
  .post-subline {
    margin-bottom: 1.25rem;
  }

  article.post-plain {
    margin: 1.25rem auto;
  }

  /* Better SVG handling for mobile */
  article.post-plain svg {
    height: auto !important;  /* Override any inline height */
    font-size: 12px !important; /* Slightly reduce SVG text size on mobile */
  }
}
</style>

<Layout
  title={post.data.title}
  description={description}
  ogType="article"
  useKatex={post.data.useKatex}
  ogImage={`/og/${post.id}.png`}
  schemaArticle={{
    title: post.data.title,
    description,
    publishedTime,
    updatedTime,
    section: post.data.cat,
    wordCount: wordCount || undefined,
    imageUrl: `${siteUrl}/og/${post.id}.png`,
  }}
  schema={{
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "home", "item": siteUrl },
      { "@type": "ListItem", "position": 2, "name": post.data.title },
    ],
  }}
>
  <ReadingProgress target="article.post-plain" />
  {showTocRail && (
    <button
      type="button"
      class="toc-mobile-toggle"
      data-toc-toggle
      aria-label="Open table of contents"
      aria-expanded="false"
      aria-controls="toc-rail"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="4" y1="6" x2="20" y2="6"></line>
        <line x1="4" y1="12" x2="14" y2="12"></line>
        <line x1="4" y1="18" x2="18" y2="18"></line>
      </svg>
    </button>
  )}
  {showTocRail && <div class="toc-mobile-backdrop" data-toc-backdrop aria-hidden="true"></div>}
  {showTocRail && (
    <button
      type="button"
      class="toc-restore"
      data-toc-restore
      aria-label="Show table of contents"
      title="Show TOC"
    >
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <line x1="8" y1="6" x2="20" y2="6"></line>
        <line x1="8" y1="12" x2="20" y2="12"></line>
        <line x1="8" y1="18" x2="20" y2="18"></line>
        <circle cx="4" cy="6" r="1"></circle>
        <circle cx="4" cy="12" r="1"></circle>
        <circle cx="4" cy="18" r="1"></circle>
      </svg>
    </button>
  )}
  {showTocRail && (
    <nav id="toc-rail" class="toc-rail" aria-label="Table of contents">
      <div class="toc-controls">
        <button
          type="button"
          class="toc-ctrl-btn"
          data-toc-pin
          aria-label="Pin table of contents"
          aria-pressed="false"
          title="Pin"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 17v5"></path>
            <path d="M9 10.76V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v6.76l2 3.24H7l2-3.24z"></path>
          </svg>
        </button>
        <button
          type="button"
          class="toc-ctrl-btn"
          data-toc-hide
          aria-label="Hide table of contents"
          title="Hide"
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="6" y1="6" x2="18" y2="18"></line>
            <line x1="6" y1="18" x2="18" y2="6"></line>
          </svg>
        </button>
      </div>
      <ol class="toc-entries">
        <li class="toc-entry toc-entry-title" data-target="top">
          <a href="#" title={post.data.title} aria-label={post.data.title}>
            <span class="toc-tick"></span>
            <span class="toc-label" data-full-text={post.data.title}>{post.data.title}</span>
          </a>
        </li>
        {tocHeadings.map(heading => (
          <li class={`toc-entry toc-d${heading.depth}`} data-target={heading.slug}>
            <a href={`#${heading.slug}`} title={heading.text} aria-label={heading.text}>
              <span class="toc-tick"></span>
              <span class="toc-label" data-full-text={heading.text}>{heading.text}</span>
            </a>
          </li>
        ))}
      </ol>
    </nav>
  )}
  <div class="centered-wrapper">
    <article class="post-plain markdown-body">
      <div class="post-meta">
        <time datetime={post.data.pubDate}>{displayDate}</time>
        <span class="post-meta-sep">•</span>
        <span class="post-readtime">{readingTimeLabel}</span>
      </div>
      <h1 class="post-title-main">{post.data.title}</h1>
      <div class="post-subline">
        {post.data.description && (
          <p class="post-description">{post.data.description}</p>
        )}
      </div>
      <Content />
      <Comments />
    </article>
  </div>
  <script type="module" src={galleryScriptUrl}></script>
  <script>
    const tocRail = document.getElementById('toc-rail');
    const tocToggle = document.querySelector('[data-toc-toggle]');
    const tocBackdrop = document.querySelector('[data-toc-backdrop]');
    const tocPinBtn = document.querySelector('[data-toc-pin]');
    const tocHideBtn = document.querySelector('[data-toc-hide]');
    const tocRestoreBtn = document.querySelector('[data-toc-restore]');

    const STORAGE_PIN = 'toc-pinned';
    const STORAGE_HIDE = 'toc-hidden';

    const applyPin = (pinned) => {
      if (!tocRail) return;
      tocRail.classList.toggle('toc-pinned', pinned);
      tocPinBtn?.setAttribute('aria-pressed', String(pinned));
    };

    const applyHide = (hidden) => {
      if (!tocRail) return;
      tocRail.classList.toggle('toc-dismissed', hidden);
      tocRestoreBtn?.classList.toggle('is-visible', hidden);
    };

    try {
      applyPin(localStorage.getItem(STORAGE_PIN) === '1');
      applyHide(localStorage.getItem(STORAGE_HIDE) === '1');
    } catch {}

    tocPinBtn?.addEventListener('click', () => {
      const next = !tocRail?.classList.contains('toc-pinned');
      applyPin(next);
      try { localStorage.setItem(STORAGE_PIN, next ? '1' : '0'); } catch {}
    });

    tocHideBtn?.addEventListener('click', () => {
      applyHide(true);
      applyPin(false);
      try {
        localStorage.setItem(STORAGE_HIDE, '1');
        localStorage.setItem(STORAGE_PIN, '0');
      } catch {}
    });

    tocRestoreBtn?.addEventListener('click', () => {
      applyHide(false);
      try { localStorage.setItem(STORAGE_HIDE, '0'); } catch {}
    });

    /* Mark TOC entries whose label text overflows so CSS tooltip shows.
       Re-run when rail width changes (collapse↔expand↔pin) since available width differs. */
    const markTruncatedLabels = () => {
      const entries = tocRail?.querySelectorAll('.toc-entry') ?? [];
      entries.forEach((entry) => {
        const label = entry.querySelector('.toc-label');
        if (!label) return;
        const truncated = label.scrollWidth > label.clientWidth + 1;
        if (truncated) entry.setAttribute('data-truncated', 'true');
        else entry.removeAttribute('data-truncated');
      });
    };
    /* Measure after layout + fonts settle */
    const scheduleTruncationCheck = () => {
      requestAnimationFrame(() => requestAnimationFrame(markTruncatedLabels));
    };
    scheduleTruncationCheck();
    if (document.fonts?.ready) document.fonts.ready.then(scheduleTruncationCheck);
    window.addEventListener('resize', scheduleTruncationCheck);
    /* Re-measure when rail transitions width (hover, pin, mobile open) */
    tocRail?.addEventListener('transitionend', (e) => {
      if (e.propertyName === 'width' || e.propertyName === 'transform') scheduleTruncationCheck();
    });

    const closeToc = () => {
      tocRail?.classList.remove('is-open');
      tocBackdrop?.classList.remove('is-open');
      tocToggle?.setAttribute('aria-expanded', 'false');
    };
    const openToc = () => {
      tocRail?.classList.add('is-open');
      tocBackdrop?.classList.add('is-open');
      tocToggle?.setAttribute('aria-expanded', 'true');
    };
    tocToggle?.addEventListener('click', () => {
      tocRail?.classList.contains('is-open') ? closeToc() : openToc();
    });
    tocBackdrop?.addEventListener('click', closeToc);
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') closeToc();
    });
  </script>
  <script>
    const tocEntries = [...document.querySelectorAll('.toc-entry')];
    if (tocEntries.length) {
      const topEntry = tocEntries.find((entry) => entry.dataset.target === 'top') ?? null;
      const sectionItems = tocEntries
        .map((entry) => {
          const id = entry.dataset.target;
          if (!id || id === 'top') return null;
          const heading = document.getElementById(id);
          if (!heading) return null;
          return { id, entry, heading };
        })
        .filter(Boolean);

      let active = null;
      let scheduled = false;
      let lockUntil = 0;

      const tocRailEl = document.getElementById('toc-rail');
      const scrollActiveIntoView = (entry) => {
        if (!entry || !tocRailEl) return;
        const railRect = tocRailEl.getBoundingClientRect();
        const entryRect = entry.getBoundingClientRect();
        const margin = 32;
        if (entryRect.top < railRect.top + margin || entryRect.bottom > railRect.bottom - margin) {
          entry.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
        }
      };

      const setActive = (entry) => {
        if (entry === active) return;
        if (active) active.classList.remove('toc-active');
        active = entry;
        if (active) {
          active.classList.add('toc-active');
          scrollActiveIntoView(active);
        }
      };

      const resolveActiveEntry = () => {
        if (!sectionItems.length) return topEntry;
        const scrollTop = window.scrollY;
        if (scrollTop <= 24) return topEntry;

        let current = topEntry;
        for (const item of sectionItems) {
          const headingTop = window.scrollY + item.heading.getBoundingClientRect().top;
          if (headingTop <= scrollTop + 96) current = item.entry;
          else break;
        }
        return current;
      };

      const updateActive = () => {
        scheduled = false;
        if (Date.now() < lockUntil) return;
        setActive(resolveActiveEntry());
      };

      const scheduleUpdate = () => {
        if (scheduled) return;
        scheduled = true;
        requestAnimationFrame(updateActive);
      };

      window.addEventListener('scroll', scheduleUpdate, { passive: true });
      window.addEventListener('resize', scheduleUpdate, { passive: true });
      window.addEventListener('load', scheduleUpdate, { once: true });
      scheduleUpdate();

      for (const entry of tocEntries) {
        entry.querySelector('a')?.addEventListener('click', (event) => {
          const target = entry.dataset.target;
          if (!target) return;

          event.preventDefault();
          setActive(entry);
          lockUntil = Date.now() + 800;

          if (target === 'top') {
            window.scrollTo({ top: 0 });
          } else {
            const heading = document.getElementById(target);
            if (!heading) return;
            heading.scrollIntoView({ block: 'start' });
          }

          const rail = document.getElementById('toc-rail');
          const backdrop = document.querySelector('[data-toc-backdrop]');
          const toggle = document.querySelector('[data-toc-toggle]');
          rail?.classList.remove('is-open');
          backdrop?.classList.remove('is-open');
          toggle?.setAttribute('aria-expanded', 'false');
        });
      }
    }
  </script>
</Layout>
