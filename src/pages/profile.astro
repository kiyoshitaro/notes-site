---
import Layout from '../layouts/Layout.astro';

const profile = {
  name: 'Hung T. Nguyen',
  handle: 'kiyoshitaro',
  phone: '(+84) 344-933-366',
  email: 'hunglhp1998@gmail.com',
  linkedin: 'linkedin.com/in/hunglhp1998',
  linkedinUrl: 'https://linkedin.com/in/hunglhp1998',
