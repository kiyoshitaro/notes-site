const skillGroups = [
  { label: 'Languages', items: ['TypeScript/JavaScript', 'Python', 'Go', 'C/C++'] },
  { label: 'Libraries', items: ['NestJS', 'SocketIO', 'BullMQ', 'Ethers.js', 'RabbitMQ'] },
  { label: 'Data Storage', items: ['PostgreSQL', 'Redis', 'TimescaleDB', 'Firestore'] },
  { label: 'Deployment', items: ['Docker', 'Git', 'Google Cloud Platform', 'Cloudflare'] },
];

const specialized = [
  'Proficient in building end-to-end backend projects using NestJS: database design, codebase, deployment.',
  'Proficient in using in-memory storage for various tasks to optimize performance.',
  'Experienced in WebSocket and many types of storage: PostgreSQL, TimescaleDB, Firestore, vectorDB.',
  'Worked with LLM/AI agents, integrating diverse data to build context-aware chatbot and automation solutions.',
  'Understanding of blockchain concepts, experienced in diverse Dapp narratives across EVM, Solana.',
  'Knowledge of containerization and cloud deployment technologies.',
];

const experience = [
  {
    company: 'Viettel Digital Services',
    role: 'Software Engineer',
    period: 'Sep 2025 - Present',
    projects: [
      {
        name: null,
        bullets: [
          'Research on blockchain technologies and proposed integration of crypto payment rails into traditional financial systems.',
          'Collaborated with team to experiment AI-driven SDLC models (spec-driven, test-driven) in building a payment gateway, leveraging agentic skills framework to automate and accelerate development.',
        ],
        accomplishments: [],
      },
    ],
  },
  {
    company: 'Lab3',
    role: 'Backend Engineer',
    period: 'April 2023 - Sep 2025',
    projects: [
      {
        name: 'Telegram Trading Bot',
        bullets: [
          'Developed a Telegram-based trading tool that relays user orders to Hyperliquid: handle complex conversation logic flows, tracking and analyzing whale signals on Hyperliquid, forwarding orders efficiently.',
          "Implemented request relayer to bypass Hyperliquid's rate limits with self-hosted rotating proxy, connection pooling, smart caching and offloaded complex API data processing. Achieved 30% latency reduction and 25–30% request savings with minimal static IPs.",
          'Built secure wallet management in isolated node, encrypted private-key storage, and transaction signing.',
        ],
        accomplishments: [
          'Led a technical team (3-4 devs) in coordinating discussions and decision-making.',
        ],
      },
      {
        name: 'LLM Apps',
        bullets: [
          'Built a crypto agent with team for social content generation, on-chain action recommendations and automated DeFi execution based on user requests.',
          'Collected external data from social platforms, on-chain data, real-time pricing, web crawlers, and search engines to enrich contextuality for LLM; optimized efficient caching mechanisms, significantly reducing requests.',
          'Responsible for tech stack decisions, core backend codebase, data collector, and deployment pipelines.',
        ],
        accomplishments: [],
      },
      {
        name: 'Gamble App',
        bullets: [
          'Developed and scaled a real-time cryptocurrency price feeding system for matching and live/OHLC charts using TimescaleDB and Socket.IO.',
          'Implemented dynamic ranking engine to track user engagement with social tasks and in-game actions for airdrop.',
        ],
        accomplishments: [
          'Extensive experience in synchronizing transactions and executing smart contracts on Solana, EVM.',
        ],
      },
    ],
  },
  {
    company: 'Neko Global / Accel3 Company',
    role: 'Backend Engineer',
    period: 'Feb 2022 - April 2023',
    projects: [
      {
        name: 'Nekoverse MMORPG',
        bullets: [
          'Built a server-authoritative game with team, mainly responsible for designing storage for multiple game modes, leaderboards, rewards, and upgrade mechanics.',
          'Primarily worked on designing the structure and implementing the logic for a turn-based game from the server side, using Colyseus WebSocket-based communication.',
        ],
        accomplishments: [
          'Proficient in BE frameworks: NestJS, ExpressJS, and skilled in Google Cloud Platform.',
          'Ability to work with both real-time communication technologies and multiple storage: PostgreSQL, Redis.',
          'Knowledgeable about microservices architecture pattern.',
        ],
      },
    ],
  },
  {
    company: 'Avepoint Company',
    role: 'Software Engineer',
    period: 'Mar 2021 - Feb 2022',
    projects: [
      {
        name: 'Azure VM Backup project',
        bullets: [
          "Implemented UI components and user's flow for the Azure VM Backup project using ReactJS.",
        ],
        accomplishments: [
          'Acquired skills in working within a systematic and global environment, enhancing communication abilities and making effective proposals.',
        ],
      },
    ],
  },
  {
    company: 'VINIF - Hanoi University of Science and Technology',
    role: 'Student Researcher',
    period: 'Dec 2020 - Dec 2021',
    projects: [
