---
const { target = 'article' } = Astro.props as { target?: string };
---
<button
  type="button"
  class="reading-progress-ring"
  data-reading-progress
  aria-label="Reading progress, scroll to top"
  title="Back to top"
  hidden
  style="--p: 0"
>
  <span class="reading-progress-inner">
    <span class="reading-progress-pct" data-reading-progress-pct>0%</span>
    <svg class="reading-progress-arrow" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
      <path d="M12 19V5"></path>
      <path d="M5 12l7-7 7 7"></path>
    </svg>
  </span>
</button>

<style>
  .reading-progress-ring {
    position: fixed;
    right: clamp(1rem, 3vw, 1.75rem);
    bottom: clamp(1rem, 3vw, 1.75rem);
    width: 52px;
    height: 52px;
    border-radius: 999px;
    border: none;
    padding: 0;
    cursor: pointer;
    z-index: 150;
    background: conic-gradient(
      var(--accent) calc(var(--p) * 1%),
      var(--border-muted) 0
    );
    box-shadow: 0 6px 18px rgba(var(--shadow-rgb), 0.22);
    opacity: 0;
    transform: translateY(8px);
    transition: opacity 0.25s ease, transform 0.25s ease, box-shadow 0.2s ease;
  }

  .reading-progress-ring[hidden] {
    display: none;
  }

  .reading-progress-ring.is-visible {
    opacity: 1;
    transform: translateY(0);
  }

  .reading-progress-ring:hover {
    box-shadow: 0 8px 22px rgba(var(--shadow-rgb), 0.28);
  }

  .reading-progress-ring:focus-visible {
    outline: 2px solid rgba(var(--accent-rgb), 0.5);
    outline-offset: 3px;
  }

  .reading-progress-inner {
    position: absolute;
    inset: 4px;
    border-radius: inherit;
    background: var(--bg);
    color: var(--fg);
    display: grid;
    place-items: center;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.02em;
    transition: background 0.2s ease, color 0.2s ease;
  }

  .reading-progress-pct {
    line-height: 1;
  }

  .reading-progress-arrow {
    display: none;
    color: var(--accent);
  }

  .reading-progress-ring:hover .reading-progress-pct {
    display: none;
  }

  .reading-progress-ring:hover .reading-progress-arrow {
    display: block;
  }

  .reading-progress-ring:hover .reading-progress-inner {
    background: var(--surface-soft);
  }

  @media (prefers-reduced-motion: reduce) {
    .reading-progress-ring {
      transition: none;
    }
  }

  @media print {
    .reading-progress-ring {
      display: none !important;
    }
  }
</style>

<script is:inline define:vars={{ target }}>
  (() => {
    const root = document.querySelector(target);
    const button = document.querySelector('[data-reading-progress]');
    const pctEl = document.querySelector('[data-reading-progress-pct]');
    if (!button || !pctEl) return;

    let scheduled = false;

    const computeProgress = () => {
      const viewport = window.innerHeight || document.documentElement.clientHeight;
      const scrollTop = window.scrollY || document.documentElement.scrollTop;

      let start = 0;
      let end = 0;
      if (root instanceof HTMLElement) {
        const rect = root.getBoundingClientRect();
        start = scrollTop + rect.top;
        end = start + rect.height - viewport;
      } else {
        end = (document.documentElement.scrollHeight || 0) - viewport;
      }

      const range = end - start;
      if (range <= 0) return scrollTop > start ? 1 : 0;
      return Math.min(1, Math.max(0, (scrollTop - start) / range));
    };

    const update = () => {
      scheduled = false;
      const p = computeProgress();
      const pct = Math.round(p * 100);
      button.style.setProperty('--p', String(pct));
      pctEl.textContent = pct + '%';
      button.setAttribute('aria-label', 'Reading progress ' + pct + '%, scroll to top');

      const showThreshold = (window.innerHeight || 600) * 0.4;
      const scrollTop = window.scrollY || document.documentElement.scrollTop;
      if (scrollTop > showThreshold) {
        button.hidden = false;
        button.classList.add('is-visible');
      } else {
        button.classList.remove('is-visible');
        if (scrollTop <= 4) button.hidden = true;
      }
    };

    const schedule = () => {
      if (scheduled) return;
      scheduled = true;
      requestAnimationFrame(update);
    };

    window.addEventListener('scroll', schedule, { passive: true });
    window.addEventListener('resize', schedule, { passive: true });
    window.addEventListener('load', schedule, { once: true });
    schedule();

    button.addEventListener('click', () => {
      const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      window.scrollTo({ top: 0, behavior: reduced ? 'auto' : 'smooth' });
    });
  })();
</script>
