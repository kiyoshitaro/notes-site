---
const { src, alt, caption } = Astro.props;
---

<figure class="ui-figure">
  <div class="ui-figure__frame">
    <img src={src} alt={alt} loading="lazy" />
  </div>
  {caption && <figcaption>{caption}</figcaption>}
</figure>

<style>
  .ui-figure {
    margin: 2rem 0;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .ui-figure__frame {
    width: 100%;
    overflow: hidden;
    border: 1px solid var(--border-soft);
    border-radius: 12px;
    background: var(--surface-soft);
  }
  .ui-figure__frame img {
    display: block;
    width: 100%;
    height: auto;
    margin: 0;
    border-radius: 0;
    box-shadow: none;
  }
  .ui-figure figcaption {
    margin-top: 0.75rem;
    font-size: 0.88rem;
    font-style: italic;
    color: var(--fg-muted);
    text-align: center;
  }
</style>
