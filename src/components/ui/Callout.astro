---
const { type = "note", title } = Astro.props;

const calloutTypes = {
  note: { defaultTitle: "Note" },
  tip: { defaultTitle: "Tip" },
  warning: { defaultTitle: "Warning" },
  danger: { defaultTitle: "Danger" },
};

const current =
  calloutTypes[type as keyof typeof calloutTypes] || calloutTypes.note;
---

<aside class={`ui-callout ui-callout--${type}`}>
  <div class="ui-callout__header">
    <span class="ui-callout__icon" aria-hidden="true">
      {type === "note" && (
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M12 16v-4"/><path d="M12 8h.01"/></svg>
      )}
      {type === "tip" && (
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>
      )}
      {type === "warning" && (
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"/><path d="M12 9v4"/><path d="M12 17h.01"/></svg>
      )}
      {type === "danger" && (
        <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/></svg>
      )}
    </span>
    <span class="ui-callout__title">{title || current.defaultTitle}</span>
  </div>
  <div class="ui-callout__body">
    <slot />
  </div>
</aside>

<style>
  .ui-callout {
    margin: 1.5rem 0;
    padding: 0.85rem 1rem;
    border-left: 3px solid var(--accent);
    border-radius: 0 6px 6px 0;
    background: var(--surface-note);
    color: var(--fg);
    font-size: 0.95rem;
  }
  .ui-callout__header {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-bottom: 0.4rem;
    font-weight: 700;
    color: var(--accent);
  }
  .ui-callout__icon {
    display: inline-flex;
    flex-shrink: 0;
    line-height: 0;
  }
  .ui-callout__title {
    font-family: var(--font-mono);
    font-size: 0.82em;
    letter-spacing: 0.04em;
    text-transform: lowercase;
  }
  .ui-callout__body :global(*:first-child) {
    margin-top: 0;
  }
  .ui-callout__body :global(*:last-child) {
    margin-bottom: 0;
  }

  .ui-callout--note {
    border-left-color: var(--cat-gpu);
  }
  .ui-callout--note .ui-callout__header {
    color: var(--cat-gpu);
  }

  .ui-callout--tip {
    border-left-color: var(--accent);
  }
  .ui-callout--tip .ui-callout__header {
    color: var(--accent);
  }

  .ui-callout--warning {
    border-left-color: var(--cat-ml);
  }
  .ui-callout--warning .ui-callout__header {
    color: var(--cat-ml);
  }

  .ui-callout--danger {
    border-left-color: var(--cat-hardware);
  }
  .ui-callout--danger .ui-callout__header {
    color: var(--cat-hardware);
  }
</style>
