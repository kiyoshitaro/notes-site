---
export interface Props {
  href: string;
  title: string;
  description?: string;
  domain?: string;
}
const { href, title, description, domain } = Astro.props;
let displayDomain = domain;
if (!displayDomain) {
  try {
    displayDomain = new URL(href).hostname;
  } catch {
    displayDomain = href;
  }
}
---

<a class="ui-linkcard" href={href} target="_blank" rel="noopener noreferrer">
  <div class="ui-linkcard__body">
    <div class="ui-linkcard__title">{title}</div>
    {description && <div class="ui-linkcard__desc">{description}</div>}
    <div class="ui-linkcard__meta">
      <svg viewBox="0 0 24 24" width="12" height="12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/>
        <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/>
      </svg>
      <span>{displayDomain}</span>
    </div>
  </div>
  <span class="ui-linkcard__arrow" aria-hidden="true">→</span>
</a>

<style>
  .ui-linkcard {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 2rem 0;
    padding: 1rem 1.25rem;
    border: 1px solid var(--border-soft);
    border-radius: 12px;
    background: var(--bg);
    color: var(--fg);
    text-decoration: none;
    transition: border-color 0.2s ease, background 0.2s ease, transform 0.2s ease;
  }
  .ui-linkcard:hover {
    border-color: var(--accent);
    background: var(--surface-soft);
    transform: translateY(-1px);
    text-decoration: none;
  }
  .ui-linkcard__body {
    flex: 1;
    min-width: 0;
  }
  .ui-linkcard__title {
    font-weight: 600;
    color: var(--fg-strong);
    margin-bottom: 0.25rem;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }
  .ui-linkcard:hover .ui-linkcard__title {
    color: var(--accent);
  }
  .ui-linkcard__desc {
    font-size: 0.9rem;
    color: var(--fg-muted);
    line-height: 1.5;
    margin-bottom: 0.6rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .ui-linkcard__meta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--fg-subtle);
  }
  .ui-linkcard__arrow {
    flex-shrink: 0;
    color: var(--accent);
    font-size: 1.4rem;
    line-height: 1;
  }
</style>
