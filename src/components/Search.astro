---
import Search from 'astro-pagefind/components/Search';
---

<aside data-pagefind-ignore>
  <div id="search-backdrop" class="search-backdrop is-hidden" aria-hidden="true">
    <div id="search-container" class="search-container" role="dialog" aria-modal="true" aria-label="Search">
      <Search
        id="search"
        className="pagefind-ui"
        uiOptions={{
          showImages: false,
          excerptLength: 15,
          resetStyles: false,
          showSubResults: true,
        }}
      />
      <div class="search-hint">
        Press <kbd>Esc</kbd> or click outside to close
      </div>
    </div>
  </div>
</aside>

<script is:inline>
  (() => {
    const backdrop = document.getElementById('search-backdrop');
    const container = document.getElementById('search-container');
    if (!backdrop || !container) return;

    const open = () => {
      backdrop.classList.remove('is-hidden');
      backdrop.setAttribute('aria-hidden', 'false');
      const input = document.querySelector('#search input');
      if (input) setTimeout(() => input.focus(), 0);
    };

    const close = () => {
      const input = document.querySelector('#search input');
      if (input) input.value = '';
      const results = document.querySelector('#search [class*="results"]');
      if (results) results.innerHTML = '';
      backdrop.classList.add('is-hidden');
      backdrop.setAttribute('aria-hidden', 'true');
    };

    document.addEventListener('click', (event) => {
      const trigger = event.target.closest('[data-search-trigger]');
      if (trigger) {
        event.preventDefault();
        open();
      }
    });

    document.addEventListener('keydown', (event) => {
      if ((event.metaKey || event.ctrlKey) && event.key === 'k') {
        event.preventDefault();
        open();
      } else if (event.key === '/') {
        const tag = document.activeElement?.tagName;
        if (tag === 'INPUT' || tag === 'TEXTAREA') return;
        if (!backdrop.classList.contains('is-hidden')) return;
        event.preventDefault();
        open();
      } else if (event.key === 'Escape') {
        close();
      }
    });

    backdrop.addEventListener('click', (event) => {
      if (!event.target.closest('#search-container')) close();
    });

    document.addEventListener('click', (event) => {
      if (event.target.classList?.contains('pagefind-ui__result-link')) close();
    });
  })();
</script>

<style is:global>
  :root {
    --pagefind-ui-scale: 0.85;
    --pagefind-ui-border-width: 1px;
    --pagefind-ui-border-radius: 6px;
    --pagefind-ui-font: var(--font-mono);
    --pagefind-ui-primary: var(--fg);
    --pagefind-ui-text: var(--fg);
    --pagefind-ui-background: var(--bg);
    --pagefind-ui-border: var(--border-soft);
    --pagefind-ui-tag: var(--surface-soft);
  }

  .search-backdrop {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: flex;
    justify-content: center;
    padding: 6vh 1rem 1rem;
    background: rgba(var(--shadow-rgb), 0.45);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
  }

  .search-backdrop.is-hidden {
    display: none;
  }

  .search-container {
    width: 100%;
    max-width: 640px;
    max-height: 80vh;
    overflow: auto;
    background: var(--bg);
    border: 1px solid var(--border-soft);
    border-radius: 10px;
    box-shadow: 0 12px 40px rgba(var(--shadow-rgb), 0.32);
    padding: 0.75rem 1rem 1rem;
    font-family: var(--font-mono);
  }

  .search-hint {
    margin-top: 0.75rem;
    padding-top: 0.6rem;
    border-top: 1px solid var(--border-soft);
    text-align: right;
    font-size: 0.72rem;
    color: var(--fg-muted);
  }

  .search-hint kbd {
    display: inline-block;
    padding: 0.05rem 0.35rem;
    font-size: 0.72rem;
    font-family: var(--font-mono);
    background: var(--surface-soft);
    border: 1px solid var(--border-soft);
    border-radius: 3px;
    color: var(--fg);
  }

  /* Pagefind UI tweaks */
  #search .pagefind-ui__form {
    margin: 0;
  }

  #search .pagefind-ui__search-input {
    font-weight: 400;
    background: var(--surface-soft);
    border: 1px solid var(--border-soft);
    color: var(--fg);
  }

  #search .pagefind-ui__search-input:focus {
    border-color: var(--accent);
    outline: none;
    box-shadow: 0 0 0 3px rgba(var(--accent-rgb), 0.2);
  }

  #search .pagefind-ui__search-clear {
    color: var(--fg-muted);
  }

  #search .pagefind-ui__result {
    border-top-color: var(--border-soft);
    padding: 0.85rem 0;
  }

  #search .pagefind-ui__result-title {
    font-weight: 600;
    color: var(--fg-strong);
  }

  #search .pagefind-ui__result-title a {
    color: var(--fg-strong);
    text-decoration: none;
  }

  #search .pagefind-ui__result-title a:hover {
    color: var(--accent);
    text-decoration: underline;
  }

  #search .pagefind-ui__result-excerpt {
    color: var(--fg-soft);
    font-size: 0.82rem;
    line-height: 1.55;
  }

  #search .pagefind-ui__result-excerpt mark {
    background: rgba(var(--accent-rgb), 0.18);
    color: var(--fg-strong);
    border-radius: 2px;
    padding: 0 0.15em;
  }

  #search .pagefind-ui__message {
    color: var(--fg-muted);
    padding: 0.5rem 0 0.75rem;
    font-size: 0.85rem;
  }

  #search .pagefind-ui__button {
    background: var(--surface-soft);
    border: 1px solid var(--border-soft);
    color: var(--fg);
    border-radius: 4px;
  }

  #search .pagefind-ui__button:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
</style>
