---
interface Props {
  id: string;
  name: string;
  chapterCount: number;
  description: string;
}

const { id, name, chapterCount, description } = Astro.props as Props;
---

<a class="book-card" href={`/book/${id}`}>
  <div class="book-icon">📘</div>
  <div class="book-content">
    <span class="book-name">{name}</span>
    <span class="book-meta">{chapterCount} chapter{chapterCount !== 1 ? 's' : ''}</span>
    <span class="book-description">{description}</span>
  </div>
</a>

<style>
  .book-card {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.85rem 1rem;
    border: 1px solid var(--border-muted);
    background: var(--bg);
    color: inherit;
    text-decoration: none;
    border-radius: 4px;
    transition: transform 0.15s, border-color 0.15s, box-shadow 0.15s;
  }

  .book-card:hover {
    transform: translateY(-1px);
    border-color: var(--border-strong);
    box-shadow: 0 4px 12px rgba(var(--shadow-rgb), 0.24);
  }

  .book-icon {
    font-size: 1.25rem;
    flex-shrink: 0;
    color: var(--fg-subtle);
    line-height: 1.2;
  }

  .book-content {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
    min-width: 0;
  }

  .book-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--fg);
  }

  .book-meta {
    font-size: 0.75rem;
    color: var(--fg-subtle);
    text-transform: lowercase;
  }

  .book-description {
    font-size: 0.78rem;
    color: var(--fg-muted);
    line-height: 1.45;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
